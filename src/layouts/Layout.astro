---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Social Media Content Generator - Optimiere YouTube Videos und LinkedIn Posts"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900">
    <header class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 py-3 flex justify-end">
        <button
          id="logout-btn"
          class="text-sm text-gray-600 hover:text-gray-900 focus:outline-none"
        >
          Abmelden
        </button>
      </div>
    </header>
    <slot />
    <script>
      document.getElementById("logout-btn")?.addEventListener("click", async () => {
        await fetch("/api/logout", { method: "POST", redirect: "manual" });
        window.location.href = "/login";
      });
    </script>
    <style is:global>
      /* Include Tailwind base styles */
      @tailwind base;
      @tailwind components;
      @tailwind utilities;

      /* Add any global base styles here if needed */
      body {
        font-family:
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Oxygen,
          Ubuntu,
          Cantarell,
          "Open Sans",
          "Helvetica Neue",
          sans-serif;
      }
    </style>
  </body>
</html>
